---
import { APP_URL } from '../config';
---

<section class="py-24 px-4">
  <div class="max-w-4xl mx-auto text-center">
    <h2
      class="text-lg sm:text-xl mb-4"
      style="font-family:var(--font-pixel);color:var(--color-maple-gold);"
    >
      See It In Action
    </h2>
    <p class="text-sm mb-12" style="color:var(--color-muted);">
      Watch the detector catch MVP announcements live and fire Discord alerts instantly.
    </p>

    <div
      class="relative"
      style="border:3px solid var(--color-maple-red);box-shadow:8px 8px 0 var(--color-maple-red);"
    >
      <img
        src="/screenshot.png"
        alt="MapleStory MVP Detector app interface showing real-time OCR detection"
        width="1200"
        height="675"
        class="w-full block"
      />
    </div>

    <a
      href={APP_URL}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-block mt-8 text-xs underline underline-offset-4"
      style="color:var(--color-maple-red);font-family:var(--font-pixel);"
    >
      Try it live →
    </a>
  </div>
</section>
