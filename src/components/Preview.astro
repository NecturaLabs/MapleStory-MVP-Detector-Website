---
import { APP_URL } from '../config';
---

<section class="py-24 px-6">
  <div class="max-w-5xl mx-auto">
    <!-- Section label -->
    <p
      class="text-center text-xs font-bold uppercase tracking-widest mb-3"
      style="color: var(--color-gold);"
    >
      Preview
    </p>
    <h2 class="text-center text-2xl sm:text-3xl font-bold mb-4" style="color: var(--color-text);">
      See it in action
    </h2>
    <p class="text-center text-sm mb-12" style="color: var(--color-text-2);">
      Watch the detector catch MVP announcements live and fire Discord alerts instantly.
    </p>

    <div
      class="rounded-lg overflow-hidden"
      style="border: 1px solid var(--color-border-2); box-shadow: 0 24px 80px rgba(0,0,0,0.5);"
    >
      <img
        src="/screenshot.png"
        alt="MapleStory MVP Detector app interface showing real-time OCR detection"
        width="1200"
        height="675"
        class="w-full block"
      />
    </div>

    <div class="text-center mt-8">
      <a
        href={APP_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-1 text-sm font-medium"
        style="color: var(--color-gold);"
      >
        Try it live →
      </a>
    </div>
  </div>
</section>
