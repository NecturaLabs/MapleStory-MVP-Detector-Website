---
import { APP_URL, GITHUB_URL } from '../config';
const year = new Date().getFullYear();
---

<footer
  class="py-10 px-6 text-center"
  style="background: var(--color-surface-2); border-top: 1px solid var(--color-border);"
>
  <div class="max-w-3xl mx-auto">
    <nav class="flex justify-center gap-8 mb-6 text-sm" aria-label="Footer navigation">
      <a
        href={APP_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="font-medium transition-colors"
        style="color: var(--color-gold);"
      >
        Launch App
      </a>
      <a
        href={GITHUB_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="transition-colors"
        style="color: var(--color-text-3);"
      >
        GitHub
      </a>
    </nav>

    <p class="text-xs mb-3" style="color: var(--color-text-3);">
      © {year} NecturaLabs. MIT License.
    </p>

    <p class="text-xs leading-relaxed max-w-xl mx-auto" style="color: var(--color-text-2);">
      This project is not affiliated with, endorsed by, or sponsored by Nexon or NEXON Korea
      Corporation. MapleStory is a trademark of Nexon.
    </p>
  </div>
</footer>
