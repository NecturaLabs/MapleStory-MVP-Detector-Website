---
import { APP_URL } from '../config';
---

<section class="py-24 px-4 text-center" style="background:var(--color-maple-red);">
  <div class="max-w-2xl mx-auto">
    <p class="text-4xl mb-4" aria-hidden="true">🍁</p>
    <h2
      class="text-base sm:text-lg mb-6"
      style="font-family:var(--font-pixel);color:#fff;text-shadow:3px 3px 0 rgba(0,0,0,0.4);"
    >
      Ready to Catch Your MVPs?
    </h2>
    <p class="text-sm mb-10" style="color:rgba(255,255,255,0.85);">
      Free forever. No sign-up. No install. Just open and go.
    </p>
    <a
      href={APP_URL}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-block px-10 py-4 text-xs font-bold uppercase tracking-wide transition-transform hover:-translate-y-1 active:translate-y-0"
      style="font-family:var(--font-pixel);background:#fff;color:var(--color-maple-red);box-shadow:4px 4px 0 rgba(0,0,0,0.3);"
    >
      Launch App →
    </a>
  </div>
</section>
