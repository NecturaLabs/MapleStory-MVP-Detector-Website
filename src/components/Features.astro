---
const features = [
  {
    icon: '⚡',
    title: 'Real-Time OCR',
    description:
      'Tesseract.js runs entirely in your browser — sub-second detection with zero server round-trips.',
  },
  {
    icon: '🎯',
    title: 'Pattern Matching',
    description:
      'Smart regex patterns filter false positives and catch every MVP announcement reliably.',
  },
  {
    icon: '🔔',
    title: 'Discord Webhooks',
    description:
      'Paste your Discord webhook URL and get instant pings in any channel or server.',
  },
  {
    icon: '📐',
    title: 'Configurable Region',
    description:
      'Select exactly which part of your screen to watch — works at any resolution or window size.',
  },
  {
    icon: '⏱️',
    title: 'Cooldown Timer',
    description:
      'Set a cooldown between alerts to avoid spam when multiple MVPs fire close together.',
  },
  {
    icon: '🌐',
    title: 'No Install Required',
    description:
      '100% browser-native. Open the app, grant screen access, and you are running.',
  },
];
---

<section class="py-24 px-4" style="background:var(--color-bg-card);">
  <div class="max-w-5xl mx-auto">
    <h2
      class="text-center text-lg sm:text-xl mb-4"
      style="font-family:var(--font-pixel);color:var(--color-maple-gold);"
    >
      Features
    </h2>
    <p class="text-center text-sm mb-16" style="color:var(--color-muted);">
      Everything you need. Nothing you don't.
    </p>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {
        features.map((feature) => (
          <div
            class="flex flex-col p-6 gap-3"
            style="border:2px solid var(--color-border);background:var(--color-bg);"
          >
            <span class="text-3xl" aria-hidden="true">{feature.icon}</span>
            <h3
              class="text-xs font-bold leading-relaxed"
              style="font-family:var(--font-pixel);color:var(--color-text);"
            >
              {feature.title}
            </h3>
            <p class="text-sm leading-relaxed" style="color:var(--color-muted);">
              {feature.description}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>
