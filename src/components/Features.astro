---
const features = [
  {
    icon: '⚡',
    title: 'Real-Time OCR',
    description:
      'Tesseract.js runs entirely in your browser — sub-second detection with zero server round-trips.',
  },
  {
    icon: '🎯',
    title: 'Pattern Matching',
    description:
      'Smart regex patterns filter false positives and catch every MVP announcement reliably.',
  },
  {
    icon: '🔔',
    title: 'Discord Webhooks',
    description:
      'Paste your Discord webhook URL and get instant pings in any channel or server.',
  },
  {
    icon: '📐',
    title: 'Configurable Region',
    description:
      'Select exactly which part of your screen to watch — works at any resolution or window size.',
  },
  {
    icon: '⏱️',
    title: 'Cooldown Timer',
    description:
      'Set a cooldown between alerts to avoid spam when multiple MVPs fire close together.',
  },
  {
    icon: '🌐',
    title: 'No Install Required',
    description:
      '100% browser-native. Open the app, grant screen access, and you are running.',
  },
];
---

<section class="py-24 px-6" style="background: var(--color-surface);">
  <div class="max-w-5xl mx-auto">
    <!-- Section label -->
    <p
      class="text-center text-xs font-bold uppercase tracking-widest mb-3"
      style="color: var(--color-gold);"
    >
      Features
    </p>
    <h2 class="text-center text-2xl sm:text-3xl font-bold mb-4" style="color: var(--color-text);">
      Everything you need
    </h2>
    <p class="text-center text-sm mb-16" style="color: var(--color-text-2);">
      Nothing you don't.
    </p>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {
        features.map((feature) => (
          <div
            class="flex flex-col p-5 rounded-lg gap-3"
            style="background: var(--color-surface-2); border: 1px solid var(--color-border);"
          >
            <span class="text-2xl" aria-hidden="true">{feature.icon}</span>
            <h3 class="text-sm font-semibold" style="color: var(--color-text);">
              {feature.title}
            </h3>
            <p class="text-sm leading-relaxed" style="color: var(--color-text-2);">
              {feature.description}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>
