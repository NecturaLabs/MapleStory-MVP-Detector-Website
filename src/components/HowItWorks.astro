---
const steps = [
  {
    number: '01',
    icon: '🖥️',
    title: 'Watch Your Screen',
    description:
      'The app captures your MapleStory window using browser screen capture — no software to install.',
  },
  {
    number: '02',
    icon: '🔍',
    title: 'Detect MVP Calls',
    description:
      'Tesseract OCR reads your in-game chat in real time and pattern-matches MVP announcement messages.',
  },
  {
    number: '03',
    icon: '🔔',
    title: 'Alert Your Discord',
    description:
      'The moment an MVP is detected, a webhook fires instantly to your configured Discord channel.',
  },
];
---

<section class="py-24 px-4">
  <div class="max-w-5xl mx-auto">
    <h2
      class="text-center text-lg sm:text-xl mb-16"
      style="font-family:var(--font-pixel);color:var(--color-maple-gold);"
    >
      How It Works
    </h2>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {
        steps.map((step, i) => (
          <div
            class="relative flex flex-col items-center text-center p-6"
            style="background:var(--color-bg-card);border:2px solid var(--color-border);"
          >
            <span
              class="text-xs mb-3"
              style="font-family:var(--font-pixel);color:var(--color-maple-red);"
            >
              {step.number}
            </span>
            <span class="text-5xl mb-4" aria-hidden="true">
              {step.icon}
            </span>
            <h3
              class="text-xs font-bold mb-3 leading-relaxed"
              style="font-family:var(--font-pixel);color:var(--color-text);"
            >
              {step.title}
            </h3>
            <p class="text-sm leading-relaxed" style="color:var(--color-muted);">
              {step.description}
            </p>
            {i < steps.length - 1 && (
              <div
                class="hidden md:block absolute -right-5 top-1/2 -translate-y-1/2 text-2xl z-10"
                style="color:var(--color-maple-red);"
              >
                ▶
              </div>
            )}
          </div>
        ))
      }
    </div>
  </div>
</section>
