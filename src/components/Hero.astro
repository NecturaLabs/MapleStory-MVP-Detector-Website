---
import { APP_URL, GITHUB_URL } from '../config';
---

<section class="relative flex flex-col items-center justify-center min-h-screen px-6 py-32 text-center overflow-hidden">
  <!-- Subtle radial glow -->
  <div
    class="absolute inset-0 pointer-events-none"
    style="background: radial-gradient(ellipse 70% 50% at 50% 0%, rgba(240,180,41,0.07) 0%, transparent 70%);"
    aria-hidden="true"
  ></div>

  <!-- Badge -->
  <div
    class="inline-flex items-center gap-2 mb-8 px-3 py-1 rounded text-xs font-semibold"
    style="background: rgba(240,180,41,0.1); color: var(--color-gold); border: 1px solid rgba(240,180,41,0.25);"
  >
    ★ Free &amp; Open Source
  </div>

  <!-- Title -->
  <h1
    class="text-4xl sm:text-5xl md:text-6xl font-bold mb-4 tracking-tight leading-tight"
    style="color: var(--color-text);"
  >
    MS MVP Detector
  </h1>

  <!-- Gold accent rule -->
  <div class="w-10 h-0.5 mb-6 rounded" style="background: var(--color-gold);"></div>

  <!-- Tagline -->
  <p class="text-base sm:text-lg max-w-lg mb-10 leading-relaxed" style="color: var(--color-text-2);">
    Real-time MVP alerts for MapleStory, straight to your Discord channel.
    No install needed — runs entirely in your browser.
  </p>

  <!-- CTAs -->
  <div class="flex flex-col sm:flex-row gap-3 justify-center">
    <a
      href={APP_URL}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-md text-sm font-semibold transition-colors"
      style="background: var(--color-gold); color: #111318;"
      onmouseover="this.style.background='#e0a820'"
      onmouseout="this.style.background='var(--color-gold)'"
    >
      Launch App →
    </a>
    <a
      href={GITHUB_URL}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-md text-sm font-semibold transition-colors"
      style="background: transparent; color: var(--color-text-2); border: 1px solid var(--color-border-2);"
      onmouseover="this.style.background='var(--color-surface-3)';this.style.color='var(--color-text)'"
      onmouseout="this.style.background='transparent';this.style.color='var(--color-text-2)'"
    >
      GitHub
    </a>
  </div>
</section>
